@@ -146,7 +146,8 @@ case "$board" in
 		;;
 	jcg,q30-pro|\
 	netcore,n60|\
-	netcore,n60-pro)
+	netcore,n60-pro|\
+	netcore,n60-pro-512rom)
 		# Originally, phy1 is phy0 mac with LA bit set. However, this would conflict
